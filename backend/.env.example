# 复制为 .env 并填入真实值（.env 已被 .gitignore 忽略，请勿提交密钥）

# 大模型 / Embedding（OpenAI 兼容接口，这里用阿里云百炼 DashScope 兼容模式）
# 阿里云百炼示例：https://dashscope.aliyuncs.com/compatible-mode/v1
API_KEY=your-api-key
API_BASE=https://your-openai-compatible-endpoint/v1

# 语音 ASR / TTS 双工 WebSocket（DashScope run-task 协议，走 inference 端点，非 realtime）
# 阿里云百炼示例：wss://dashscope.aliyuncs.com/api-ws/v1/inference
WSS_URL=wss://your-speech-inference-endpoint

# 音色复刻 REST 地址
# 阿里云百炼示例：https://dashscope.aliyuncs.com/api/v1/services/audio/tts/customization
VOICE_URL=https://your-voice-clone-endpoint
